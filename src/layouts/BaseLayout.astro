---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "timurgromov.ru",
  description = "Стартовый Astro-каркас для переноса лендинга с Tilda.",
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
