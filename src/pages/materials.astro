---
import { readFileSync } from "node:fs";

const basePath = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const pageUrl = new URL(`${basePath}materials/`, "https://timurgromov.github.io").toString();

const pageHtml = readFileSync(
  new URL("../../page62008353.html", import.meta.url),
  "utf-8",
);
const bodySource = readFileSync(
  new URL("../../files/page62008353body.html", import.meta.url),
  "utf-8",
);

const headMatch = pageHtml.match(/<head>([\s\S]*?)<\/head>/i);
const bodyTagMatch = pageHtml.match(/<body([^>]*)>/i);
const allRecordsMatch = bodySource.match(/<div id="allrecords"([^>]*)>/i);

if (!headMatch) {
  throw new Error("Не удалось извлечь <head> из page62008353.html");
}

if (!bodyTagMatch) {
  throw new Error("Не удалось извлечь <body> из page62008353.html");
}

if (!allRecordsMatch) {
  throw new Error("Не удалось извлечь #allrecords из files/page62008353body.html");
}

const bodyAttrs = bodyTagMatch[1];
const bodyClass = bodyAttrs.match(/\bclass=(['"])(.*?)\1/i)?.[2];
const bodyStyle = bodyAttrs.match(/\bstyle=(['"])(.*?)\1/i)?.[2];
const allRecordsAttrs = allRecordsMatch[1];

const materialRecordIds = [
  // Webinar.
  "rec862714733",
  "rec905176327",
  "rec861962232",
  "rec862050095",
  "rec863346882",
  "rec862643056",
  "rec862643109",
  // Advice video carousel.
  "rec862713715",
  "rec862055949",
  "rec862301619",
  "rec862070380",
  "rec893268511",
  "rec893268655",
  "rec893271079",
  "rec893271232",
  "rec893273557",
  "rec893273581",
  "rec893275111",
  "rec893275240",
  "rec893277967",
  "rec893278048",
  "rec893280313",
  "rec893281054",
];
const headerRecordId = "rec862699342";
const footerRecordId = "rec862623921";
const materialsFooterMenuIds = [
  "1738908769393",
  "1738908801867",
  "1738908837275",
  "1738908848846",
  "1738908861448",
  "1738908872836",
  "1738908883710",
];

const mobileWebinarRecordId = "rec862050095";
const mobileWebinarBadgeTriggerOffsets: Record<string, string> = {
  "1738828748021": "211",
  "1738828827988": "211",
  "1738828912673": "217",
};
const mobileWebinarCardTriggerOffsets: Record<string, string> = {
  "173883092613938130": "262",
  "173883093344499820": "262",
  "173883205939691230": "262",
};

function extractTildaRecord(html: string, recordId: string) {
  const startMarker = `<div id="${recordId}"`;
  const startIndex = html.indexOf(startMarker);

  if (startIndex === -1) {
    throw new Error(`Не найдена Tilda-запись ${recordId}`);
  }

  const nextRecordIndex = html.indexOf(' <div id="rec', startIndex + startMarker.length);
  const endIndex = nextRecordIndex === -1 ? html.length : nextRecordIndex;

  return html.slice(startIndex, endIndex);
}

function withBasePath(html: string) {
  return html
    .replace(/href=(['"])(?!https?:|mailto:|tel:|#|\/{2})(\/?)(?!\/)/g, `href=$1${basePath}`)
    .replace(/src=(['"])(?!https?:|data:|\/{2})(\/?)(?!\/)/g, `src=$1${basePath}`)
    .replace(/action=(['"])(?!https?:|mailto:|tel:|#|\/{2})(\/?)(?!\/)/g, `action=$1${basePath}`)
    .replace(/content=(['"])images\//g, `content=$1${basePath}images/`)
    .replace(/data-original=(['"])(?!https?:|data:|\/{2})(\/?)(?!\/)/g, `data-original=$1${basePath}`)
    .replace(/&quot;images\//g, `&quot;${basePath}images/`)
    .replace(/url\(['"]?(?!https?:|data:|\/{2})(\/?)(?!\/)/g, `url('${basePath}`);
}

function patchMobileWebinarBadgeTriggers(
  recordHtml: string,
  triggerOffsets: Record<string, string>,
) {
  return Object.entries(triggerOffsets).reduce((html, [elementId, triggerOffset]) => {
    const elementPattern = new RegExp(
      `(<div\\b[^>]*data-elem-id=(["'])${elementId}\\2[^>]*?)\\sdata-animate-fix-trgofst-res-320=(["'])[^"']*\\3`,
      "g",
    );

    return html.replace(
      elementPattern,
      `$1 data-animate-fix-trgofst-res-320="${
        triggerOffset
      }"`,
    );
  }, recordHtml);
}

function patchMobileWebinarCardTriggers(
  recordHtml: string,
  triggerOffsets: Record<string, string>,
) {
  return Object.entries(triggerOffsets).reduce((html, [groupId, triggerOffset]) => {
    const groupPattern = new RegExp(
      `(<div\\b[^>]*data-group-id=(["'])${groupId}\\2[^>]*?)\\sdata-animate-sbs-trgofst-res-320=(["'])[^"']*\\3`,
      "g",
    );

    return html.replace(
      groupPattern,
      `$1 data-animate-sbs-trgofst-res-320="${triggerOffset}"`,
    );
  }, recordHtml);
}

const materialRecordsHtml = materialRecordIds
  .map((recordId) => {
    const recordHtml = extractTildaRecord(bodySource, recordId);

    if (recordId !== mobileWebinarRecordId) {
      return recordHtml;
    }

    return patchMobileWebinarCardTriggers(
      patchMobileWebinarBadgeTriggers(recordHtml, mobileWebinarBadgeTriggerOffsets),
      mobileWebinarCardTriggerOffsets,
    );
  })
  .join(" ");
const headerRecordHtml = extractTildaRecord(bodySource, headerRecordId);
const footerRecordHtml = extractTildaRecord(bodySource, footerRecordId);

const headHtml = withBasePath(
  headMatch[1]
    .replace(/<title>[\s\S]*?<\/title>/i, "<title>Полезные материалы подготовки к свадьбе</title>")
    .replace(
      /<meta name="description" content="[^"]*"\s*\/?>/i,
      '<meta name="description" content="Вебинар и короткие видео с советами по подготовке к свадьбе" />',
    )
    .replace(
      /<meta property="og:url" content="[^"]*"\s*\/?>/i,
      `<meta property="og:url" content="${pageUrl}" />`,
    )
    .replace(/<link rel="canonical" href="[^"]*"\s*\/?>/i, `<link rel="canonical" href="${pageUrl}" />`)
    .concat(
      `<script>window.t396_elem_fixLineHeight=window.t396_elem_fixLineHeight||function(){return;};</script>`,
    )
    .concat(
      `<style>
        body.t-body{background:#fffefa !important;}
        #allrecords{
          padding-top:81px;
        }
        #rec862699342{
          position:fixed !important;
          top:0;
          left:0;
          width:100%;
          z-index:9997;
        }
        #rec862699342 .t396__artboard,
        #rec862699342 .t396__carrier,
        #rec862699342 .t396__filter,
        #rec862699342 .tn-elem[data-elem-id="1738923690320"] .tn-atom{
          background:#fa4604 !important;
          background-color:#fa4604 !important;
        }
        #rec862699342 .t396__artboard{
          overflow:hidden;
          border-radius:0 0 10px 10px;
        }
        #rec862699342 .tn-elem{
          pointer-events:auto;
        }
        .materials-header-copy{
          position:fixed;
          top:0;
          left:50%;
          z-index:9998;
          width:min(860px, calc(100vw - 420px));
          height:81px;
          display:flex;
          align-items:center;
          justify-content:center;
          transform:translateX(-50%);
          pointer-events:none;
          color:#fffefa;
          text-align:center;
          font-family:'Coolvetica',Arial,sans-serif;
          font-size:34px;
          line-height:0.74;
          font-weight:300;
          white-space:nowrap;
        }
        @media screen and (max-width:1919px){
          #allrecords{
            padding-top:55px;
          }
          .materials-header-copy{
            width:min(640px, calc(100vw - 290px));
            height:55px;
            font-size:26px;
          }
        }
        @media screen and (max-width:1199px){
          #allrecords{
            padding-top:53px;
          }
          .materials-header-copy{
            width:min(360px, calc(100vw - 210px));
            height:53px;
            font-size:17px;
          }
        }
        @media screen and (max-width:639px){
          #allrecords{
            padding-top:72px;
          }
          #rec862699342 .t396__artboard,
          #rec862699342 .t396__carrier,
          #rec862699342 .t396__filter{
            height:72px !important;
          }
          #rec862699342 .tn-elem[data-elem-id="1738923690320"]{
            height:72px !important;
          }
          #rec862699342 .tn-elem[data-elem-id="1738923690320"] .tn-atom{
            height:72px !important;
          }
          .materials-header-copy{
            width:120px;
            top:14px;
            right:74px;
            left:auto;
            height:40px;
            transform:none;
            font-size:8px;
            line-height:0.9;
            white-space:normal;
          }
        }
        ${materialsFooterMenuIds
          .map(
            (elementId) => `
        #rec862623921 .tn-elem[data-elem-id="${elementId}"],
        #rec862623921 .tn-elem[data-elem-id="${elementId}"] .tn-atom{
          display:none !important;
          opacity:0 !important;
          visibility:hidden !important;
          pointer-events:none !important;
        }`,
          )
          .join("")}
        #rec862070380 .tn-elem a[href^="#popup:video-soveti-"]{
          position:relative;
          display:block;
          width:100%;
          height:100%;
          overflow:hidden;
        }
        #rec862070380 .tn-elem a[href^="#popup:video-soveti-"]::before{
          content:"";
          position:absolute;
          left:50%;
          top:50%;
          width:38px;
          height:38px;
          border-radius:999px;
          background:rgba(255,255,255,.28);
          border:1.5px solid rgba(255,255,255,.56);
          box-shadow:0 6px 14px rgba(28,27,26,.12);
          backdrop-filter:blur(1.5px);
          transform:translate(-50%,-50%);
          pointer-events:none;
        }
        #rec862070380 .tn-elem a[href^="#popup:video-soveti-"]::after{
          content:"";
          position:absolute;
          left:calc(50% + 2px);
          top:50%;
          width:0;
          height:0;
          border-top:7px solid transparent;
          border-bottom:7px solid transparent;
          border-left:11px solid rgba(250,70,4,.78);
          transform:translate(-50%,-50%);
          pointer-events:none;
        }
        @media screen and (max-width:1199px){
          #rec862070380 .tn-elem a[href^="#popup:video-soveti-"]::before{
            width:34px;
            height:34px;
          }
          #rec862070380 .tn-elem a[href^="#popup:video-soveti-"]::after{
            left:calc(50% + 2px);
            border-top-width:6px;
            border-bottom-width:6px;
            border-left-width:10px;
          }
        }
        @media screen and (max-width:639px){
          #rec862623921 .tn-elem[data-elem-id="1738906924130"],
          #rec862623921 .tn-elem[data-elem-id="1738906924130"] .tn-atom{
            height:620px !important;
          }
          #rec862623921 .tn-elem[data-elem-id="1738909017957"]{
            top:650px !important;
          }
          #rec862623921 .tn-elem[data-elem-id="1738909098665"],
          #rec862623921 .tn-elem[data-elem-id="1739077659698"]{
            top:736px !important;
          }
          #rec862623921 .tn-elem[data-elem-id="1738909152475"]{
            top:788px !important;
          }
          #rec862623921 .tn-elem[data-elem-id="1738909098668"]{
            top:811px !important;
          }
          #rec862070380 .tn-elem a[href^="#popup:video-soveti-"]::before{
            width:30px;
            height:30px;
          }
          #rec862070380 .tn-elem a[href^="#popup:video-soveti-"]::after{
            left:calc(50% + 2px);
            border-top-width:5px;
            border-bottom-width:5px;
            border-left-width:8px;
          }
        }
      </style>`,
    ),
);

const bodyHtml = withBasePath(
  `${headerRecordHtml}<div class="materials-header-copy" aria-hidden="true">Тут вы узнаете много полезностей</div><!--allrecords--> <div id="allrecords"${allRecordsAttrs}>${materialRecordsHtml} ${footerRecordHtml}</div> <!--/allrecords-->`,
);
---

<!doctype html>
<html lang="ru">
  <head>
    <Fragment set:html={headHtml} />
  </head>
  <body class={bodyClass} style={bodyStyle} set:html={bodyHtml}></body>
</html>
