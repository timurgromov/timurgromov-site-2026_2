          #rec862070380 .tn-elem a[href^="#popup:video-soveti-"]::after{
            left:calc(50% + 2px);
            border-top-width:5px;
            border-bottom-width:5px;
            border-left-width:8px;
          }
        }
      </style>`,
    ),
);

const bodyHtml = withBasePath(
  `<div class="materials-header-shell">${headerRecordHtml}<div class="materials-header-copy" aria-hidden="true">Тут вы узнаете много полезностей</div></div><!--allrecords--> <div id="allrecords"${allRecordsAttrs}>${materialRecordsHtml} ${footerRecordHtml}</div> <!--/allrecords-->`,
);
---

<!doctype html>
<html lang="ru">
  <head>
    <Fragment set:html={headHtml} />
  </head>
  <body class={bodyClass} style={bodyStyle} set:html={bodyHtml}></body>
</html>
