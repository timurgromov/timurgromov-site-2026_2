---
import { readFileSync } from "node:fs";

const basePath = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const pageUrl = new URL(`${basePath}materials/`, "https://timurgromov.github.io").toString();

const pageHtml = readFileSync(
  new URL("../../page62008353.html", import.meta.url),
  "utf-8",
);
const bodySource = readFileSync(
  new URL("../../files/page62008353body.html", import.meta.url),
  "utf-8",
);

const headMatch = pageHtml.match(/<head>([\s\S]*?)<\/head>/i);
const bodyTagMatch = pageHtml.match(/<body([^>]*)>/i);
const allRecordsMatch = bodySource.match(/<div id="allrecords"([^>]*)>/i);

if (!headMatch) {
  throw new Error("Не удалось извлечь <head> из page62008353.html");
}

if (!bodyTagMatch) {
  throw new Error("Не удалось извлечь <body> из page62008353.html");
}

if (!allRecordsMatch) {
  throw new Error("Не удалось извлечь #allrecords из files/page62008353body.html");
}

const bodyAttrs = bodyTagMatch[1];
const bodyClass = bodyAttrs.match(/\bclass=(['"])(.*?)\1/i)?.[2];
const bodyStyle = bodyAttrs.match(/\bstyle=(['"])(.*?)\1/i)?.[2];
const allRecordsAttrs = allRecordsMatch[1];

const materialRecordIds = [
  // Webinar.
  "rec862714733",
  "rec905176327",
  "rec861962232",
  "rec862050095",
  "rec863346882",
  "rec862643056",
  "rec862643109",
  // Advice video carousel.
  "rec862713715",
  "rec862055949",
  "rec862301619",
  "rec862070380",
  "rec893268511",
  "rec893268655",
  "rec893271079",
  "rec893271232",
  "rec893273557",
  "rec893273581",
  "rec893275111",
  "rec893275240",
  "rec893277967",
  "rec893278048",
  "rec893280313",
  "rec893281054",
];

const webinarBadgeElementIds = [
  "1738828748021",
  "1738828827988",
  "1738828912673",
];

function extractTildaRecord(html: string, recordId: string) {
  const startMarker = `<div id="${recordId}"`;
  const startIndex = html.indexOf(startMarker);

  if (startIndex === -1) {
    throw new Error(`Не найдена Tilda-запись ${recordId}`);
  }

  const nextRecordIndex = html.indexOf(' <div id="rec', startIndex + startMarker.length);
  const endIndex = nextRecordIndex === -1 ? html.length : nextRecordIndex;

  return html.slice(startIndex, endIndex);
}

function withBasePath(html: string) {
  return html
    .replace(/href=(['"])(?!https?:|mailto:|tel:|#|\/{2})(\/?)(?!\/)/g, `href=$1${basePath}`)
    .replace(/src=(['"])(?!https?:|data:|\/{2})(\/?)(?!\/)/g, `src=$1${basePath}`)
    .replace(/action=(['"])(?!https?:|mailto:|tel:|#|\/{2})(\/?)(?!\/)/g, `action=$1${basePath}`)
    .replace(/content=(['"])images\//g, `content=$1${basePath}images/`)
    .replace(/data-original=(['"])(?!https?:|data:|\/{2})(\/?)(?!\/)/g, `data-original=$1${basePath}`)
    .replace(/&quot;images\//g, `&quot;${basePath}images/`)
    .replace(/url\(['"]?(?!https?:|data:|\/{2})(\/?)(?!\/)/g, `url('${basePath}`);
}

function stripTildaFixedAnimation(html: string, elementIds: string[]) {
  const idPattern = elementIds.map((id) => id.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")).join("|");
  const elemTagPattern = new RegExp(`<div\\b(?=[^>]*data-elem-id=(["'])(${idPattern})\\1)[^>]*>`, "g");

  return html.replace(elemTagPattern, (tag) =>
    tag.replace(/\sdata-animate-(?:fix(?:-(?:dist|trgofst(?:-res-\d+)?))?|mobile)=(["'])[^"']*\1/g, ""),
  );
}

const materialRecordsHtml = stripTildaFixedAnimation(
  materialRecordIds.map((recordId) => extractTildaRecord(bodySource, recordId)).join(" "),
  webinarBadgeElementIds,
);

const webinarBadgePinScript = `
<script>
(function () {
  var records = [
    { id: "861962232", videoId: "1739078296052" },
    { id: "862050095", videoId: "1739078914882" }
  ];
  var badgeParts = [
    { id: "1738828748021", desktopX: 32 / 880, mobileX: 10 / 300, desktopW: 64 / 880, mobileW: 32 / 300, desktopH: 64 / 480, mobileH: 32 / 181, topOffset: 0 },
    { id: "1738828827988", desktopX: 104 / 880, mobileX: 48 / 300, desktopW: 375 / 880, mobileW: 186 / 300, desktopH: 64 / 480, mobileH: 32 / 181, topOffset: 0 },
    { id: "1738828912673", desktopX: 120 / 880, mobileX: 56 / 300, desktopW: 343 / 880, mobileW: 178 / 300, desktopH: 38 / 480, mobileH: 24 / 181, topOffset: 0.2 }
  ];

  function setImportant(element, name, value) {
    element.style.setProperty(name, value, "important");
  }

  function pinRecordBadge(recordConfig) {
    var record = document.getElementById("rec" + recordConfig.id);
    if (!record || getComputedStyle(record).display === "none") return;

    var video = record.querySelector('[data-elem-id="' + recordConfig.videoId + '"]');
    var badgeBackground = record.querySelector('[data-elem-id="1738828827988"]');
    if (!video || !badgeBackground) return;

    var videoWidth = video.offsetWidth || video.getBoundingClientRect().width;
    var videoHeight = video.offsetHeight || video.getBoundingClientRect().height;
    if (!videoWidth || !videoHeight) return;

    var isMobile = window.matchMedia("(max-width: 639px)").matches;
    var badgeHeight = videoHeight * (isMobile ? 32 / 181 : 64 / 480);
    var bottomGap = badgeHeight * (isMobile ? 9 / 32 : 0.5);
    var badgeTop = videoHeight - bottomGap - badgeHeight;

    badgeParts.forEach(function (part) {
      var element = record.querySelector('[data-elem-id="' + part.id + '"]');
      if (!element) return;

      if (element.parentElement !== video) {
        video.appendChild(element);
      }

      var top = badgeTop + badgeHeight * part.topOffset;
      var left = videoWidth * (isMobile ? part.mobileX : part.desktopX);
      var width = videoWidth * (isMobile ? part.mobileW : part.desktopW);
      var height = videoHeight * (isMobile ? part.mobileH : part.desktopH);

      setImportant(element, "position", "absolute");
      setImportant(element, "top", Math.round(top) + "px");
      setImportant(element, "left", Math.round(left) + "px");
      setImportant(element, "width", Math.round(width) + "px");
      setImportant(element, "height", part.id === "1738828912673" ? "auto" : Math.round(height) + "px");
      setImportant(element, "transform", "none");
      setImportant(element, "z-index", "20");
      setImportant(element, "visibility", "visible");
    });
  }

  function pinBadges() {
    records.forEach(pinRecordBadge);
    window.requestAnimationFrame(pinBadges);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", pinBadges);
  } else {
    pinBadges();
  }
}());
</script>`;

const headHtml = withBasePath(
  headMatch[1]
    .replace(/<title>[\s\S]*?<\/title>/i, "<title>Полезные материалы подготовки к свадьбе</title>")
    .replace(
      /<meta name="description" content="[^"]*"\s*\/?>/i,
      '<meta name="description" content="Вебинар и короткие видео с советами по подготовке к свадьбе" />',
    )
    .replace(
      /<meta property="og:url" content="[^"]*"\s*\/?>/i,
      `<meta property="og:url" content="${pageUrl}" />`,
    )
    .replace(/<link rel="canonical" href="[^"]*"\s*\/?>/i, `<link rel="canonical" href="${pageUrl}" />`)
    .concat(
      `<script>window.t396_elem_fixLineHeight=window.t396_elem_fixLineHeight||function(){return;};</script>`,
    )
    .concat(webinarBadgePinScript)
    .concat(`<style>body.t-body{background:#fffefa !important;}</style>`),
);

const bodyHtml = withBasePath(
  `<!--allrecords--> <div id="allrecords"${allRecordsAttrs}>${materialRecordsHtml}</div> <!--/allrecords-->`,
);
---

<!doctype html>
<html lang="ru">
  <head>
    <Fragment set:html={headHtml} />
  </head>
  <body class={bodyClass} style={bodyStyle} set:html={bodyHtml}></body>
</html>
