function removeTildaRecord(html: string, recordId: string) {
  const startMarker = `<div id="${recordId}"`;
  const startIndex = html.indexOf(startMarker);

  if (startIndex === -1) {
    return html;
  }

  const nextRecordIndex = html.indexOf(' <div id="rec', startIndex + startMarker.length);
  const endIndex = nextRecordIndex === -1 ? html.length : nextRecordIndex;

  return `${html.slice(0, startIndex)}${html.slice(endIndex)}`;
}

function removeTildaElement(html: string, elemId: string) {
  const elemMarker = `data-elem-id='${elemId}'`;
  const markerIndex = html.indexOf(elemMarker);

  if (markerIndex === -1) {
    return html;
  }

  const startIndex = html.lastIndexOf("<div class='t396__elem", markerIndex);

  if (startIndex === -1) {
    return html;
  }

  const nextElementIndex = html.indexOf(" <div class='t396__elem", markerIndex);
  const endIndex = nextElementIndex === -1 ? html.length : nextElementIndex;

  return `${html.slice(0, startIndex)}${html.slice(endIndex)}`;
}

function injectBeforeTildaRecordScript(
  html: string,
  recordNumericId: string,
  markup: string,
) {
  const marker =
    `</div> </div> <scr` +
    `ipt>t_onFuncLoad('t396_initialScale',function() {t396_initialScale('${recordNumericId}');});`;

  if (!html.includes(marker)) {
    return html;
  }

  return html.replace(marker, `${markup}${marker}`);
}
const heroAutoplayBooster = `<style>
  #rec861352716 .tn-elem__8613527161738731141089 video::-webkit-media-controls{
    display:none !important;
  }
  #rec861352716 .tn-elem__8613527161738731141089 video::-webkit-media-controls-start-playback-button{
    display:none !important;
    -webkit-appearance:none;
  }
</style>
<script>
  (function() {
    var heroRecordId = 'rec861352716';
    var heroShapeSelector = '.tn-elem__8613527161738731141089';
    var retryTimer = 0;
    var retryCount = 0;
    var maxRetries = 24;
    var activeVideo = null;
    var mobilePosterUrl = '${heroPosterMobileUrl}';
    var desktopPosterUrl = '${heroPosterDesktopUrl}';

    function getHeroPosterUrl() {
      return window.matchMedia('(max-width: 639px)').matches
        ? mobilePosterUrl
        : desktopPosterUrl;
    }

    function getHeroVideo() {
      var record = document.getElementById(heroRecordId);
      var shape = record && record.querySelector(heroShapeSelector);
      return shape && shape.querySelector('video');
    }

    function markHeroVideoStarted(video) {
      var record = document.getElementById(heroRecordId);
      if (!record || !isPlaying(video)) return;
      record.classList.add('hero-video-started');
      record.classList.add('hero-preload-hidden');
    }

    function primeVideo(video) {
      if (!video) return null;

      activeVideo = video;
      video.muted = true;
      video.defaultMuted = true;
      video.volume = 0;
      video.autoplay = true;
      video.loop = true;
      video.playsInline = true;
      video.controls = false;
      video.preload = 'auto';
      video.poster = getHeroPosterUrl();
      video.setAttribute('muted', '');
      video.setAttribute('autoplay', '');
      video.setAttribute('loop', '');
      video.setAttribute('playsinline', '');
      video.setAttribute('webkit-playsinline', '');
      video.setAttribute('preload', 'auto');
      video.setAttribute('poster', getHeroPosterUrl());
      video.removeAttribute('controls');
      markHeroVideoStarted(video);

      try {
        video.disablePictureInPicture = true;
        video.disableRemotePlayback = true;
      } catch (error) {
        return video;
      }

      return video;
    }

    function isPlaying(video) {
      return video && !video.paused && !video.ended && video.readyState >= 2;
    }

    function playHeroVideo() {
      var video = primeVideo(activeVideo || getHeroVideo());
      var playPromise;

      if (!video || isPlaying(video)) return;

      try {
        playPromise = video.play();
      } catch (error) {
        return;
      }

      if (playPromise && typeof playPromise.then === 'function') {
        playPromise.then(function() {
          markHeroVideoStarted(video);
        });
      }

      if (playPromise && typeof playPromise.catch === 'function') {
        playPromise.catch(function() {
          return;
        });
      }
    }

    function scheduleAutoplayRetries() {
      window.clearTimeout(retryTimer);

      function tick() {
        var video = primeVideo(getHeroVideo());

        if (!video) {
          retryTimer = window.setTimeout(tick, 200);
          return;
        }

        playHeroVideo();

        if (isPlaying(video)) {
          markHeroVideoStarted(video);
          return;
        }

        if (retryCount >= maxRetries) return;
        retryCount += 1;
        retryTimer = window.setTimeout(tick, 300);
      }

      retryCount = 0;
      tick();
    }

    function bindGestureFallback() {
      function handleGesture() {
        playHeroVideo();

        window.setTimeout(function() {
          if (!isPlaying(activeVideo)) return;
          markHeroVideoStarted(activeVideo);
          window.removeEventListener('touchstart', handleGesture, true);
          window.removeEventListener('pointerdown', handleGesture, true);
          window.removeEventListener('mousedown', handleGesture, true);
          window.removeEventListener('click', handleGesture, true);
        }, 120);
      }

      window.addEventListener('touchstart', handleGesture, { passive: true, capture: true });
      window.addEventListener('pointerdown', handleGesture, { passive: true, capture: true });
      window.addEventListener('mousedown', handleGesture, true);
      window.addEventListener('click', handleGesture, true);
    }

    function observeHeroVideo() {
      var target = document.getElementById(heroRecordId) || document.body;
      if (!target) return;

      var observer = new MutationObserver(function() {
        var video = primeVideo(getHeroVideo());
        if (!video) return;
        
        video.addEventListener('loadedmetadata', playHeroVideo);
        video.addEventListener('loadeddata', playHeroVideo);
        video.addEventListener('canplay', playHeroVideo);
        video.addEventListener('playing', markHeroVideoStarted.bind(null, video));
        video.addEventListener('timeupdate', markHeroVideoStarted.bind(null, video));
        playHeroVideo();
      });

      observer.observe(target, { childList: true, subtree: true });
      window.setTimeout(function() {
        observer.disconnect();
      }, 12000);
    }

    function initHeroAutoplayBooster() {
      bindGestureFallback();
      observeHeroVideo();
      scheduleAutoplayRetries();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroAutoplayBooster, { once: true });
    } else {
      initHeroAutoplayBooster();
    }

    window.addEventListener('load', scheduleAutoplayRetries);
    window.addEventListener('pageshow', scheduleAutoplayRetries);
    window.addEventListener('resize', function() {
      primeVideo(activeVideo || getHeroVideo());
    });
    document.addEventListener('visibilitychange', function() {
      if (!document.hidden) scheduleAutoplayRetries();
    });
  })();
</script>`;

