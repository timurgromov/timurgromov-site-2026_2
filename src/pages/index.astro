    function updateShortcutBlock(config) {
      var artboard = document.querySelector(config.artboardSelector);
      var phoneElem = document.querySelector(config.phoneSelector);
      if (!artboard || !phoneElem) return;

      var block = createShortcutBlock(config);
      if (!block) return;

      var artboardRect = artboard.getBoundingClientRect();
      var phoneRect = phoneElem.getBoundingClientRect();
      if (!phoneRect.width || !phoneRect.height || !artboardRect.width || !artboardRect.height) return;

      var isMobile = window.matchMedia('(max-width: 639px)').matches;
      var gap = isMobile ? 10 : 14;
      var left = Math.max(10, Math.round(phoneRect.left - artboardRect.left));

      block.style.maxWidth = Math.max(180, Math.round(artboardRect.width - left - 10)) + 'px';
      block.style.visibility = 'hidden';
      block.style.left = left + 'px';
      block.style.top = '0px';

      var blockHeight = block.offsetHeight || 0;
      var top = Math.round(phoneRect.bottom - artboardRect.top + gap);

      if (isMobile && config.placeAbovePhoneOnMobile) {
        top = Math.round(phoneRect.top - artboardRect.top - blockHeight - gap);
        top = Math.max(44, top);
      }

      block.style.top = top + 'px';
      block.style.visibility = 'visible';

      var socialElems = (config.socialSelectors || [])
        .map(function(selector) {
          return document.querySelector(selector);
        })
        .filter(Boolean);

      var socialRowBottom = top;
      if (socialElems.length) {
        var rowTop = Infinity;
        var rowBottom = -Infinity;

        socialElems.forEach(function(elem) {
          var rect = elem.getBoundingClientRect();
          if (!rect.width && !rect.height) return;
          rowTop = Math.min(rowTop, rect.top - artboardRect.top);
          rowBottom = Math.max(rowBottom, rect.bottom - artboardRect.top);
        });

        if (rowTop !== Infinity && rowBottom !== -Infinity) {
          var socialGap = isMobile ? 8 : 14;
          var socialTop = top + block.offsetHeight + socialGap;

          socialElems.forEach(function(elem) {
            var rect = elem.getBoundingClientRect();
            if (!rect.width && !rect.height) return;
            var delta = rect.top - artboardRect.top - rowTop;
            elem.style.top = Math.round(socialTop + delta) + 'px';
          });

          socialRowBottom = socialTop + (rowBottom - rowTop);
        }
      }

      if (config.emailSelector) {
        var emailElem = document.querySelector(config.emailSelector);
        if (emailElem) {
          var emailTop = socialRowBottom + (isMobile ? 12 : 18);
          emailElem.style.top = emailTop + 'px';
        }
      }
    }

    function updateAllShortcutBlocks() {
      blocks.forEach(updateShortcutBlock);
