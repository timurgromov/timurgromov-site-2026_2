---
import { readFileSync } from "node:fs";

const basePath = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const previewUrl = new URL(basePath, "https://timurgromov.github.io").toString();

const pageHtml = readFileSync(
  new URL("../../page62008353.html", import.meta.url),
  "utf-8",
);
const bodySource = readFileSync(
  new URL("../../files/page62008353body.html", import.meta.url),
  "utf-8",
);

const headMatch = pageHtml.match(/<head>([\s\S]*?)<\/head>/i);
const bodyTagMatch = pageHtml.match(/<body([^>]*)>/i);

if (!headMatch) {
  throw new Error("Не удалось извлечь <head> из page62008353.html");
}

if (!bodyTagMatch) {
  throw new Error("Не удалось извлечь <body> из page62008353.html");
}

const bodyAttrs = bodyTagMatch[1];
const bodyClass = bodyAttrs.match(/\bclass=(['"])(.*?)\1/i)?.[2];
const bodyStyle = bodyAttrs.match(/\bstyle=(['"])(.*?)\1/i)?.[2];
const heroPosterDesktopDataUrl = `data:image/jpeg;base64,${readFileSync(
  new URL("../../images/hero-poster-desktop.jpg", import.meta.url),
  "base64",
)}`;
const heroPosterMobileDataUrl = `data:image/jpeg;base64,${readFileSync(
  new URL("../../images/hero-poster-mobile.jpg", import.meta.url),
  "base64",
)}`;
const heroDesktopVideoUrl =
  "https://global.s3.cloud.ru/tg26video-public/hero-desktop.mp4";
const heroMobileVideoUrl =
  "https://global.s3.cloud.ru/tg26video-public/hero-mobile.mp4";
const heroVideoLayer = `<video
  class="hero-video-layer"
  muted
  playsinline
  autoplay
  loop
  preload="auto"
  aria-hidden="true"
></video>`;
const heroPosterLayer = `<picture class="hero-poster-layer" aria-hidden="true">
  <source
    media="(max-width: 639px)"
    srcset="${heroPosterMobileDataUrl}"
  />
  <img
    class="hero-poster-img"
    src="${heroPosterDesktopDataUrl}"
    alt=""
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
</picture>`;

const headHtml = headMatch[1]
  .replace(
    /<meta property="og:url" content="[^"]*"\s*\/?>/i,
    `<meta property="og:url" content="${previewUrl}" />`,
  )
  .replace(/<link rel="canonical" href="[^"]*"\s*\/?>/i, "")
  // В экспорт не попала вспомогательная Tilda-функция, которая иногда вызывается inline-скриптами.
  .concat(
    `<script>window.t396_elem_fixLineHeight=window.t396_elem_fixLineHeight||function(){return;};</script>`,
  )
  .concat(
    `<style>
      #rec861352716 .tn-elem__8613527161738731141089 .tn-atom{
        position:relative;
        background-image:url('${heroPosterDesktopDataUrl}');
        background-size:cover;
        background-position:center center;
        background-repeat:no-repeat;
        overflow:hidden;
      }
      #rec861352716 .tn-elem__8613527161738731141089 .hero-poster-layer{
        position:absolute;
        inset:0;
        z-index:0;
        display:block;
        pointer-events:none;
        transition:opacity .45s ease;
      }
      #rec861352716 .tn-elem__8613527161738731141089 .hero-poster-img{
        width:100%;
        height:100%;
        display:block;
        object-fit:cover;
        object-position:center center;
      }
      #rec861352716 .tn-elem__8613527161738731141089 .hero-video-layer{
        position:relative;
        z-index:1;
        opacity:0;
        transition:opacity .45s ease;
        object-fit:cover;
        object-position:center center;
      }
      #rec861352716.hero-video-visible .tn-elem__8613527161738731141089 .hero-poster-layer{
        opacity:0;
      }
      #rec861352716.hero-video-visible .tn-elem__8613527161738731141089 .hero-video-layer{
        opacity:1;
      }
      @media screen and (max-width:639px){
        #rec861352716 .tn-elem__8613527161738731141089 .tn-atom{
          background-image:url('${heroPosterMobileDataUrl}');
          background-position:center center;
        }
        #rec861352716 .tn-elem__8613527161738731141089 .hero-video-layer{
          object-position:center center;
        }
        #rec861352716 .tn-elem__8613527161738731141089 .hero-poster-img{
          object-position:center center;
        }
      }
    </style>`,
  )
  .concat(
    `<script>
      (function() {
        var heroRecordId = 'rec861352716';
        var heroShapeSelector = '.tn-elem__8613527161738731141089';
        var startDelayMs = 900;
        var heroDesktopVideoUrl = '${heroDesktopVideoUrl}';
        var heroMobileVideoUrl = '${heroMobileVideoUrl}';

        function initHeroVideoPoster() {
          var record = document.getElementById(heroRecordId);
          if (!record) return false;

          var shape = record.querySelector(heroShapeSelector);
          if (!shape) return false;

          function getHeroVideoUrl() {
            return window.matchMedia('(max-width: 639px)').matches
              ? heroMobileVideoUrl
              : heroDesktopVideoUrl;
          }

          function createHeroVideo() {
            var atom = shape.querySelector('.tn-atom');
            if (!atom) return null;

            var video = atom.querySelector('.hero-video-layer');
            if (!video) {
              video = document.createElement('video');
              video.className = 'hero-video-layer';
              video.setAttribute('muted', '');
              video.setAttribute('playsinline', '');
              video.setAttribute('autoplay', '');
              video.setAttribute('loop', '');
              video.setAttribute('preload', 'auto');
              video.setAttribute('aria-hidden', 'true');
              atom.appendChild(video);
            }

            return video;
          }

          function attachVideo(video) {
            if (!video) return false;

            var resolvedVideoUrl = getHeroVideoUrl();
            if (video.dataset.heroSource !== resolvedVideoUrl) {
              record.classList.remove('hero-video-visible');
              video.dataset.heroSource = resolvedVideoUrl;
              video.src = resolvedVideoUrl;
              video.load();
            }

            if (video.dataset.heroDelayedInit === '1') return true;

            video.dataset.heroDelayedInit = '1';
            video.muted = true;
            video.playsInline = true;
            video.preload = 'auto';

            var minDelayPassed = false;
            var videoReady = video.readyState >= 2;

            function revealVideoIfReady() {
              if (!minDelayPassed || !videoReady) return;
              record.classList.add('hero-video-visible');
            }

            function markVideoReady() {
              videoReady = true;
              revealVideoIfReady();
            }

            function markMinDelayPassed() {
              minDelayPassed = true;
              revealVideoIfReady();
            }

            function warmVideoPlayback() {
              var playPromise;

              try {
                playPromise = video.play();
              } catch (error) {
                return;
              }

              if (playPromise && typeof playPromise.catch === 'function') {
                playPromise.catch(function() {
                  return;
                });
              }
            }

            video.addEventListener('loadeddata', markVideoReady, { once: true });
            video.addEventListener('canplay', markVideoReady, { once: true });
            video.addEventListener('playing', markVideoReady, { once: true });
            window.setTimeout(markMinDelayPassed, startDelayMs);

            warmVideoPlayback();
            window.setTimeout(warmVideoPlayback, 250);

            return true;
          }

          return attachVideo(createHeroVideo());
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHeroVideoPoster, { once: true });
        } else {
          initHeroVideoPoster();
        }

        window.addEventListener('pageshow', initHeroVideoPoster);
      })();
    </script>`,
  );

const bodyHtml = bodySource
  // На GitHub Pages якоря и возврат в начало страницы должны вести в BASE_URL.
  .replace(/href=(['"])\/(?!\/)/g, `href=$1${basePath}`)
  .replace(/src=(['"])\/(?!\/)/g, `src=$1${basePath}`)
  .replace(/action=(['"])\/(?!\/)/g, `action=$1${basePath}`)
  .replace(
    /https:\/\/cdnv\.boomstream\.com\/balancer\/p1VrFFDa-SxJPiQup\.mp4/g,
    "",
  )
  .replace(
    /(<div class='t396__elem tn-elem tn-elem__8613527161738731141089'[\s\S]*?<div class='tn-atom'>)(\s*<\/div>)/,
    `$1${heroPosterLayer}${heroVideoLayer}$2`,
  );
---

<!doctype html>
<html lang="ru">
  <head>
    <Fragment set:html={headHtml} />
  </head>
  <body class={bodyClass} style={bodyStyle} set:html={bodyHtml}></body>
</html>
