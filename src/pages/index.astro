---
import { readFileSync } from "node:fs";

const basePath = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const previewUrl = new URL(basePath, "https://timurgromov.github.io").toString();

const pageHtml = readFileSync(
  new URL("../../page62008353.html", import.meta.url),
  "utf-8",
);
const bodySource = readFileSync(
  new URL("../../files/page62008353body.html", import.meta.url),
  "utf-8",
);

const headMatch = pageHtml.match(/<head>([\s\S]*?)<\/head>/i);
const bodyTagMatch = pageHtml.match(/<body([^>]*)>/i);

if (!headMatch) {
  throw new Error("Не удалось извлечь <head> из page62008353.html");
}

if (!bodyTagMatch) {
  throw new Error("Не удалось извлечь <body> из page62008353.html");
}

const bodyAttrs = bodyTagMatch[1];
const bodyClass = bodyAttrs.match(/\bclass=(['"])(.*?)\1/i)?.[2];
const bodyStyle = bodyAttrs.match(/\bstyle=(['"])(.*?)\1/i)?.[2];
const heroBoomstreamVideoUrl =
  "https://cdnv.boomstream.com/balancer/p1VrFFDa-SxJPiQup.mp4";
const heroCloudDesktopVideoUrl =
  "https://global.s3.cloud.ru/tg26video-public/hero-desktop.mp4";
const heroCloudMobileVideoUrl =
  "https://global.s3.cloud.ru/tg26video-public/hero-mobile.mp4";
const heroCloudVideoExpression = `(window.matchMedia("(max-width: 639px)").matches ? "${heroCloudMobileVideoUrl}" : "${heroCloudDesktopVideoUrl}")`;
const heroPosterVersion = "2306bab";
const heroPosterDesktopUrl = `${basePath}images/hero-poster-desktop.jpg?v=${heroPosterVersion}`;
const heroPosterMobileUrl = `${basePath}images/hero-poster-mobile.jpg?v=${heroPosterVersion}`;
const heroPosterLayer = `<picture class="hero-poster-layer" aria-hidden="true">
  <source
    media="(max-width: 639px)"
    srcset="${heroPosterMobileUrl}"
  />
  <img
    class="hero-poster-img"
    src="${heroPosterDesktopUrl}"
    alt=""
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
</picture>`;
const fastFirstPaint = `<link rel="preconnect" href="https://global.s3.cloud.ru" crossorigin>
<link
  rel="preload"
  as="image"
  href="${heroPosterDesktopUrl}"
  media="(min-width: 640px)"
  fetchpriority="high"
>
<link
  rel="preload"
  as="image"
  href="${heroPosterMobileUrl}"
  media="(max-width: 639px)"
  fetchpriority="high"
>
<style>
  html,
  body.t-body{
    background:#1c1b1a !important;
  }
  body.t-body .t-records,
  body.t-body .t-records_animated{
    opacity:1 !important;
    visibility:visible !important;
    transition:none !important;
  }
  #t-header{
    position:fixed !important;
    top:0 !important;
    left:0 !important;
    right:0 !important;
    width:100% !important;
    z-index:9990 !important;
    background:transparent !important;
  }
  html:not(.hero-header-solid) #rec862699342,
  html:not(.hero-header-solid) #rec862699342 .t396__artboard,
  html:not(.hero-header-solid) #rec862699342 .t396__carrier,
  html:not(.hero-header-solid) #rec862699342 .t396__filter,
  html:not(.hero-header-solid) #rec862699342 .tn-elem__8626993421738923690320 .tn-atom{
    background:transparent !important;
    background-color:transparent !important;
  }
  #rec861352716 .t396__artboard,
  #rec861352716 .t396__carrier,
  #rec861352716 .t396__filter{
    background-color:#1c1b1a !important;
  }
  #rec861352716 .t396__artboard:not(.rendered) .tn-elem:not(.tn-elem__8613527161738731141089){
    visibility:hidden !important;
    opacity:0 !important;
    pointer-events:none !important;
  }
  #rec861352716 .tn-elem__8613527161738731141089{
    top:0 !important;
    left:0 !important;
    width:100% !important;
    min-width:100% !important;
  }
  #rec861352716 .tn-elem__8613527161738731141089 .tn-atom{
    position:relative;
    background-image:url("${heroPosterDesktopUrl}");
    background-size:cover;
    background-position:center center;
    background-repeat:no-repeat;
    background-color:#1c1b1a !important;
    overflow:hidden;
  }
  #rec861352716 .tn-elem__8613527161738731141089 > .hero-poster-layer{
    position:absolute;
    inset:0;
    z-index:20;
    display:none;
    pointer-events:none;
    background-image:url("${heroPosterDesktopUrl}");
    background-size:cover;
    background-position:center center;
    background-repeat:no-repeat;
    background-color:#1c1b1a;
    opacity:1;
    transition:opacity .2s ease;
  }
  #rec861352716 .tn-elem__8613527161738731141089 > .hero-poster-layer .hero-poster-img{
    width:100%;
    height:100%;
    display:block;
    object-fit:cover;
    object-position:center center;
  }
  #rec861352716 .tn-elem__8613527161738731141089 video{
    opacity:0 !important;
    transition:opacity .2s ease;
  }
  #rec861352716.hero-video-started .tn-elem__8613527161738731141089 video{
    opacity:1 !important;
  }
  #rec861352716.hero-video-started .tn-elem__8613527161738731141089 > .hero-poster-layer{
    opacity:0;
  }
  @media screen and (max-width:639px){
    #rec861352716 .tn-elem__8613527161738731141089 .tn-atom{
      background-image:url("${heroPosterMobileUrl}");
    }
    #rec861352716 .tn-elem__8613527161738731141089 > .hero-poster-layer{
      display:block;
      background-image:url("${heroPosterMobileUrl}");
    }
    #rec861352716 .tn-elem[data-elem-id="1738734490081"],
    #rec861352716 .tn-elem[data-elem-id="1738734580173"],
    #rec861352716 .tn-elem[data-elem-id="1739347764973"],
    #rec861352716 .tn-elem[data-elem-id="1738734590180"],
    #rec861352716 .tn-elem[data-elem-id="1738734598281"],
    #rec861352716 .tn-elem[data-elem-id="1738734608842"],
    #rec861352716 .tn-elem[data-elem-id="1739347669889"],
    #rec861352716 .tn-elem[data-elem-id="1738734864010"],
    #rec861352716 .tn-elem[data-elem-id="1738734864006"],
    #rec861352716 .tn-elem[data-elem-id="1738734864002"],
    #rec861352716 .tn-elem[data-elem-id="1738734863997"],
    #rec861352716 .tn-elem[data-elem-id="1738734863990"]{
      display:none !important;
      opacity:0 !important;
      visibility:hidden !important;
      pointer-events:none !important;
    }
  }
</style>
<script>
  (function() {
    function syncHeroHeaderState() {
      document.documentElement.classList.toggle('hero-header-solid', window.scrollY > 520);
    }

    syncHeroHeaderState();
    window.addEventListener('scroll', syncHeroHeaderState, { passive: true });
    window.addEventListener('resize', syncHeroHeaderState);
    window.addEventListener('pageshow', syncHeroHeaderState);
  })();
</script>`;
const heroAutoplayBooster = `<style>
  #rec861352716 .tn-elem__8613527161738731141089 video::-webkit-media-controls{
    display:none !important;
  }
  #rec861352716 .tn-elem__8613527161738731141089 video::-webkit-media-controls-start-playback-button{
    display:none !important;
    -webkit-appearance:none;
  }
</style>
<script>
  (function() {
    var heroRecordId = 'rec861352716';
    var heroShapeSelector = '.tn-elem__8613527161738731141089';
    var retryTimer = 0;
    var retryCount = 0;
    var maxRetries = 24;
    var activeVideo = null;
    var mobilePosterUrl = '${heroPosterMobileUrl}';
    var desktopPosterUrl = '${heroPosterDesktopUrl}';

    function getHeroPosterUrl() {
      return window.matchMedia('(max-width: 639px)').matches
        ? mobilePosterUrl
        : desktopPosterUrl;
    }

    function getHeroVideo() {
      var record = document.getElementById(heroRecordId);
      var shape = record && record.querySelector(heroShapeSelector);
      return shape && shape.querySelector('video');
    }

    function markHeroVideoStarted(video) {
      var record = document.getElementById(heroRecordId);
      if (!record || !isPlaying(video)) return;
      record.classList.add('hero-video-started');
    }

    function primeVideo(video) {
      if (!video) return null;

      activeVideo = video;
      video.muted = true;
      video.defaultMuted = true;
      video.volume = 0;
      video.autoplay = true;
      video.loop = true;
      video.playsInline = true;
      video.controls = false;
      video.preload = 'auto';
      video.poster = getHeroPosterUrl();
      video.setAttribute('muted', '');
      video.setAttribute('autoplay', '');
      video.setAttribute('loop', '');
      video.setAttribute('playsinline', '');
      video.setAttribute('webkit-playsinline', '');
      video.setAttribute('preload', 'auto');
      video.setAttribute('poster', getHeroPosterUrl());
      video.removeAttribute('controls');
      markHeroVideoStarted(video);

      try {
        video.disablePictureInPicture = true;
        video.disableRemotePlayback = true;
      } catch (error) {
        return video;
      }

      return video;
    }

    function isPlaying(video) {
      return video && !video.paused && !video.ended && video.readyState >= 2;
    }

    function playHeroVideo() {
      var video = primeVideo(activeVideo || getHeroVideo());
      var playPromise;

      if (!video || isPlaying(video)) return;

      try {
        playPromise = video.play();
      } catch (error) {
        return;
      }

      if (playPromise && typeof playPromise.then === 'function') {
        playPromise.then(function() {
          markHeroVideoStarted(video);
        });
      }

      if (playPromise && typeof playPromise.catch === 'function') {
        playPromise.catch(function() {
          return;
        });
      }
    }

    function scheduleAutoplayRetries() {
      window.clearTimeout(retryTimer);

      function tick() {
        var video = primeVideo(getHeroVideo());

        if (!video) {
          retryTimer = window.setTimeout(tick, 200);
          return;
        }

        playHeroVideo();

        if (isPlaying(video)) {
          markHeroVideoStarted(video);
          return;
        }

        if (retryCount >= maxRetries) return;
        retryCount += 1;
        retryTimer = window.setTimeout(tick, 300);
      }

      retryCount = 0;
      tick();
    }

    function bindGestureFallback() {
      function handleGesture() {
        playHeroVideo();

        window.setTimeout(function() {
          if (!isPlaying(activeVideo)) return;
          markHeroVideoStarted(activeVideo);
          window.removeEventListener('touchstart', handleGesture, true);
          window.removeEventListener('pointerdown', handleGesture, true);
          window.removeEventListener('mousedown', handleGesture, true);
          window.removeEventListener('click', handleGesture, true);
        }, 120);
      }

      window.addEventListener('touchstart', handleGesture, { passive: true, capture: true });
      window.addEventListener('pointerdown', handleGesture, { passive: true, capture: true });
      window.addEventListener('mousedown', handleGesture, true);
      window.addEventListener('click', handleGesture, true);
    }

    function observeHeroVideo() {
      var target = document.getElementById(heroRecordId) || document.body;
      if (!target) return;

      var observer = new MutationObserver(function() {
        var video = primeVideo(getHeroVideo());
        if (!video) return;
        
        video.addEventListener('loadedmetadata', playHeroVideo);
        video.addEventListener('loadeddata', playHeroVideo);
        video.addEventListener('canplay', playHeroVideo);
        video.addEventListener('playing', markHeroVideoStarted.bind(null, video));
        video.addEventListener('timeupdate', markHeroVideoStarted.bind(null, video));
        playHeroVideo();
      });

      observer.observe(target, { childList: true, subtree: true });
      window.setTimeout(function() {
        observer.disconnect();
      }, 12000);
    }

    function initHeroAutoplayBooster() {
      bindGestureFallback();
      observeHeroVideo();
      scheduleAutoplayRetries();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroAutoplayBooster, { once: true });
    } else {
      initHeroAutoplayBooster();
    }

    window.addEventListener('load', scheduleAutoplayRetries);
    window.addEventListener('pageshow', scheduleAutoplayRetries);
    window.addEventListener('resize', function() {
      primeVideo(activeVideo || getHeroVideo());
    });
    document.addEventListener('visibilitychange', function() {
      if (!document.hidden) scheduleAutoplayRetries();
    });
  })();
</script>`;

const headHtml = headMatch[1]
  .replace(
    /<meta property="og:url" content="[^"]*"\s*\/?>/i,
    `<meta property="og:url" content="${previewUrl}" />`,
  )
  .replace(/<link rel="canonical" href="[^"]*"\s*\/?>/i, "")
  // В экспорт не попала вспомогательная Tilda-функция, которая иногда вызывается inline-скриптами.
  .concat(
    `<script>window.t396_elem_fixLineHeight=window.t396_elem_fixLineHeight||function(){return;};</script>`,
  )
  .concat(
    fastFirstPaint,
  )
  .concat(
    heroAutoplayBooster,
  );

const bodyHtml = bodySource
  // На GitHub Pages якоря и возврат в начало страницы должны вести в BASE_URL.
  .replace(/href=(['"])\/(?!\/)/g, `href=$1${basePath}`)
  .replace(/src=(['"])\/(?!\/)/g, `src=$1${basePath}`)
  .replace(/action=(['"])\/(?!\/)/g, `action=$1${basePath}`)
  .replaceAll(
    `"data":"${heroBoomstreamVideoUrl}"`,
    `"data":"${heroCloudDesktopVideoUrl}"`,
  )
  .replace(
    `link = '${heroBoomstreamVideoUrl}' ? (function() { let link = '${heroBoomstreamVideoUrl}'.trim();`,
    `link = ${heroCloudVideoExpression} ? (function() { let link = ${heroCloudVideoExpression}.trim();`,
  )
  .replace(
    /(<div class='t396__elem tn-elem tn-elem__8613527161738731141089'[\s\S]*?<div class='tn-atom'>\s*<\/div>)/,
    `$1${heroPosterLayer}`,
  );
---

<!doctype html>
<html lang="ru">
  <head>
    <Fragment set:html={headHtml} />
  </head>
  <body class={bodyClass} style={bodyStyle} set:html={bodyHtml}></body>
</html>
